<style>
  /* Make navbar relative */
  .navbar .container-fluid {
    position: relative;
  }

  /* Fix search bar in center */
  .search-wrapper {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Prevent shrinking */
  .search-wrapper input {
    width: 280px;
  }

  .search-input {
    border-radius: 20px;
    padding: 0.5rem 4rem 0.5rem 5.5rem;
    font-size: 1rem;
  }

  .search-btn i {
    display: inline;
    margin-right: 0.5rem;
  }

  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 20px;
    padding: 0 1rem 0 1rem;
  }

  .search-btn:hover {
    background-color: #c02731;
    color: white;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>


      <div class="search-wrapper">
        <form class="d-flex" role="search">
          <input class="form-control me-2 search-input" type="search" placeholder="Search homes..."
            aria-label="Search" />
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
        <% if(currUser) { %>
          <% if(currUser.role==="user" ) { %>
            <a class="nav-link" href="/bookings/my">My Bookings</a>
            <% } else { %>
              <a class="nav-link" href="/listings/new">Wandero your home</a>
              <a class="nav-link" href="/dashboard">Dashboard</a>
              <% } %>
                <% } %>


                  <% if(!currUser) { %>
                    <a class="nav-link login-btn" href="/login"><b><i class="fa-solid fa-right-to-bracket"></i> Log
                        in</b></a>
                    <a class="btn signup-btn" href="/signup"><i class="fa-solid fa-user-plus"></i> Sign up</a>
                    <% } %>


                      <!-- Profile Menu -->
                      <% if(currUser) { %>
                        <div class="nav-item dropdown">
                          <a class="nav-link d-flex align-items-center gap-2 dropdown-toggle user-menu" href="#"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">

                            <img
                              src="<%= currUser.avatar ||  'https://images.unsplash.com/photo-1633332755192-727a05c4013d' %>"
                              class="rounded-circle border" width="32" height="32" style="object-fit: cover;" />
                          </a>

                          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2">
                            <!-- User Info -->
                            <li class="px-3 py-2">
                              <div class="fw-semibold">
                                <%= currUser.username %>
                              </div>
                              <small class="text-muted">
                                <%= currUser.email %>
                              </small>
                            </li>

                            <li>
                              <hr class="dropdown-divider">
                            </li>

                            <!-- Menu Options -->
                            <li>
                              <a class="dropdown-item d-flex align-items-center gap-2" href="/profile">
                                <i class="fa-regular fa-user"></i> Profile
                              </a>
                            </li>

                            <li>
                              <form action="/switch-role" method="POST">
                                <button class="dropdown-item d-flex align-items-center gap-2">
                                  <i class="fa-solid fa-user-gear"></i>
                                  Switch to <%= currUser.role==="admin" ? "travelling" : "hosting" %>
                                </button>
                              </form>
                            </li>

                            <li>
                              <a class="dropdown-item d-flex align-items-center gap-2" href="/privacy">
                                <i class="fa-solid fa-shield-halved"></i> Privacy
                              </a>
                            </li>

                            <li>
                              <a class="dropdown-item d-flex align-items-center justify-content-between" href="#"
                                onclick="toggleMode()">
                                <span class="d-flex align-items-center gap-2">
                                  <i class="fa-solid fa-moon"></i> Mode
                                </span>
                                <span id="mode-text" class="small text-muted">Dark</span>
                              </a>
                            </li>

                            <li>
                              <a class="dropdown-item d-flex align-items-center gap-2" href="/settings">
                                <i class="fa-solid fa-gear"></i> Settings
                              </a>
                            </li>

                            <li>
                              <hr class="dropdown-divider">
                            </li>

                            <!-- Logout -->
                            <li>
                              <a class="dropdown-item text-danger d-flex align-items-center gap-2" href="/logout">
                                <i class="fa-solid fa-right-from-bracket"></i> Logout
                              </a>
                            </li>

                          </ul>
                        </div>
                        <% } %>
      </div>
    </div>
  </div>
</nav>