<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h2 class="col-6 offset-3">Email Verification</h2>
<div class="col-6 offset-3">

    <form action="/verify" method="POST" class="needs-validation" novalidate>
        <div class="mb-3 mt-5">
            <label for="username" class="form-label">Enter the OTP : </label>
            <input type="text" name="otp" placeholder="Enter 6 digits OTP"  class="form-control" required>
        </div>
            <button type="submit" class="btn btn-success">Verify</button>  
    </form>
    
</div>
</div>
