<% layout("/layouts/boilerplate") %>

<style>
  .special {
    color: #fe424d;
    font-weight: 600;
}

.card {
    border-radius: 14px;
}

.card-body {
    padding: 16px;
}

.card-text {
    font-size: 0.9rem;
    color: #444;
}
</style>

  <script>
    const mapToken = "<%= process.env.MAP_TOKEN %>"
    const listing = <% - JSON.stringify(listing) %>
  </script>

  <div class="row mt-3">
    <div class="col-lg-8 mx-auto">
      <h3>
        <%= listing.title%>
      </h3>
    </div>

    <div class="card listing-card col-lg-8 mx-auto show-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">

      <div class="card-body">
        <div class="card-body">
          <p class="card-text"><b>Host :</b>
            <span class="special" title="owner">
              <%= listing.owner.username %>
            </span>
          </p>
          <div></div>
        </div>
        <p class="card-text"><b>Description : </b>
          <%= listing.description %>
        </p>
        <p class="card-text"><b>Price : </b>&#8377;<%= listing.price.toLocaleString("en-IN")%>
        </p>
        <p class="card-text"><b>Location : </b>
          <%= listing.location %>
        </p>
        <p class="card-text"><b>Country : </b>
          <%= listing.country %>
        </p>
      </div>

    </div>
  </div>

  <% if(currUser && listing.owner._id.equals(currUser._id)){ %>
   <div class="d-flex justify-content-between align-items-center col-lg-8 mx-auto ">

  <!-- Left (Edit) -->
  <a href="/listings/<%= listing._id %>/edit" 
     class="btn btn-dark px-4">
     Edit
  </a>

  <!-- Right (Delete) -->
  <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
    <button class="btn btn-outline-danger px-4">
      Delete
    </button>
  </form>

</div>
    <% } %>

<% if(!currUser || currUser.role !== "admin") { %>
       <div class="col-lg-8 mx-auto mb-4">
    <hr>
    <form action="/bookings" method="POST" class="p-3 shadow-sm rounded bg-white">
        <input type="hidden" name="listingId" value="<%= listing._id %>">
        <h5 class="mb-3 fw-semibold">Book Your Stay</h5>
        <!-- Dates Row -->
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-medium">Check-in</label>
                <input type="date" name="checkIn" class="form-control" required>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-medium">Check-out</label>
                <input type="date" name="checkOut" class="form-control" required>
            </div>
        </div>
        <!-- Button -->
        <div class="mt-3">
            <button class="btn btn-danger w-100 fw-semibold">
                Book Now
            </button>
        </div>
    </form>
</div>
    <% } %>







<% if(!currUser || currUser.role !== "admin") { %>
        <div class="col-lg-8 mx-auto mb-3">
        <hr>
        <% if(currUser){ %>
          <h4>Leave a Review</h4>
          <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
              <label for="rating" class="form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                  aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
            <div class="mb-3 mt-3">
              <label for="comment" class="form-label">Comments</label>
              <textarea type="text" id="comment" rows="4" cols="30" name="review[comment]" class="form-control"
                required></textarea>
              <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
          </form>
          <hr>
          <% } %>

            <% if(listing.reviews.length> 0) { %>
             <div class="container mt-4">

  <h5 class="fw-bold mb-3 text-center">All Reviews</h5>

  <div class="row justify-content-center g-3">

    <% for(review of listing.reviews) { %>

      <div class="col-lg-5 col-md-6">

        <div class="card shadow-sm h-100">

          <div class="card-body">

            <p class="card-title mb-1">
              <span class="special">
                <i class="fa-solid fa-circle-user"></i>
                <%= review.author.username %>
              </span>
            </p>

            <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>

            <p class="card-text">
              <%= review.comment %>
            </p>

          </div>

          <!-- Delete Button -->
          <div class="px-3 pb-3">
            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
              <button class="btn btn-sm btn-outline-danger w-100">
                <i class="fa-solid fa-trash-can"></i> Delete
              </button>
            </form>
          </div>

        </div>

      </div>

    <% } %>

  </div>

</div>
              <% } %>
      </div>
      <% } %>

      
      <!-- <div class="col-6 offset-3 mb-3">
          <h3>Where you'll be</h3>
          <div id="map"></div>
        </div> -->
      </div>
      <br>

      <script src="/js/map.js"></script>